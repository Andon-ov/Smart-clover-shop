<?xml version="1.0" encoding="WINDOWS-1251"?>
<!-- 
  ТЕСТОВ ПРИМЕР ЗА ЗАЯВКА ЗА ДОСТАВКА 
  Формат: RDELIV (ПРАВИЛЕН формат за EboIn входящи документи!)
  Според официална документация: Раздел 5 "Входящи документи"
  
  ВАЖНО: BOSDOCUMENTS е ГРЕШЕН формат - той е за ИЗХОДЯЩИ документи (EboOut)!
  За ВХОДЯЩИ документи (EboIn) се използва само RDELIV формат!
-->
<RDELIV>
  <REQD>
    <!-- TYP: Тип на документа -->
    <!-- 1 = Заявка за доставка (delivery request) -->
    <!-- 2 = Поръчка (order) -->
    <TYP>1</TYP>
    
    <!-- SEIK: ЕИК на контрагента (ЗАДЪЛЖИТЕЛНО!) -->
    <SEIK>123456789</SEIK>
    
    <!-- DNMB: Номер на документа (ТРЯБВА да е число! Не повече от 2147483647) -->
    <DNMB>738060663</DNMB>
    
    <!-- CMNT: Коментар/забележки -->
    <CMNT>Тестова поръчка от онлайн магазин</CMNT>
    
    <!-- DDATE: Дата на документа (YYYYMMDD) -->
    <DDATE>20260128</DDATE>
    
    <!-- DTIME: Час на документа (HHMMSS) -->
    <DTIME>093743</DTIME>
    
    <!-- STORG: Номер на склад (1 = основен склад) -->
    <STORG>1</STORG>
    
    <!-- PLUES: Списък с артикули -->
    <PLUES>
      <!-- PLU: Артикул -->
      <PLU>
        <!-- PLUNB: Вътрешен код на артикула в системата -->
        <PLUNB>1</PLUNB>
        
        <!-- PLUNN: Външен код на артикула -->
        <PLUNN>BRD001</PLUNN>
        
        <!-- QTY: Количество (с точка за десетични) -->
        <QTY>2.000</QTY>
        
        <!-- PRC: Цена -->
        <PRC>2.50</PRC>
        
        <!-- CURR: Валута -->
        <CURR>BGN</CURR>
        
        <!-- PCMNT: Коментар за артикула (може да е празно) -->
        <PCMNT></PCMNT>
      </PLU>
      
      <PLU>
        <PLUNB>2</PLUNB>
        <PLUNN>MLK001</PLUNN>
        <QTY>1.000</QTY>
        <PRC>3.20</PRC>
        <CURR>BGN</CURR>
        <PCMNT></PCMNT>
      </PLU>
      
      <PLU>
        <PLUNB>3</PLUNB>
        <PLUNN>CHZ001</PLUNN>
        <QTY>1.500</QTY>
        <PRC>12.80</PRC>
        <CURR>BGN</CURR>
        <PCMNT></PCMNT>
      </PLU>
    </PLUES>
  </REQD>
</RDELIV>
