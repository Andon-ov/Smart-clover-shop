# ============================================================
# Smart Clover Bridge - Environment Variables
# Copy this file to .env and fill in the values.
# The .env file must NEVER be committed to version control.
# ============================================================

# --- MariaDB (WordPress) ---
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=change_me_wp

# --- PostgreSQL (Sync Engine) ---
POSTGRES_DB=sync_bridge
POSTGRES_USER=sync_user
POSTGRES_PASSWORD=change_me_sync

# --- FTP Server ---
# The public IP/hostname that Detelina uses to reach this machine.
FTP_PUBLIC_HOST=localhost
FTP_USER_NAME=detelina
FTP_USER_PASS=change_me_ftp

# --- WooCommerce REST API ---
# Generate these keys in WooCommerce → Settings → Advanced → REST API.
WP_KEY=ck_your_woocommerce_consumer_key
WP_SECRET=cs_your_woocommerce_consumer_secret

# --- Webhook ---
# Secret used to sign webhook payloads from WooCommerce.
# Generate with: openssl rand -base64 32
# Leave empty to skip signature verification (not recommended for production).
WEBHOOK_SECRET=change_me_webhook_secret
